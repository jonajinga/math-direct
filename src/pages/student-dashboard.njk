---
layout: layouts/base.njk
title: Student Progress
description: View individual student progress across all 150 lessons. Select a student, review phase completion, and identify what to work on next.
permalink: /student/
bodyClass: page-lessons
---
<div class="dashboard">
  <div class="dashboard__inner">
    <h1 style="font-size:1.5rem;font-weight:800;margin-bottom:var(--space-xs)">Student Progress</h1>
    <p style="font-size:0.875rem;color:var(--text-secondary);margin-bottom:var(--space-lg)">Select a student to view their progress, next steps, and phase breakdown.</p>

    {# Student selector — populated by JS #}
    <div id="sd-student-picker"></div>

    {# Student overview — populated by JS #}
    <div id="student-overview"></div>

    {# Next lesson recommendation #}
    <div id="student-next"></div>

    {# Phase progress bars #}
    <div id="student-phases"></div>

    {# Completed lesson list #}
    <div id="student-completed"></div>

    <div style="text-align:center;margin-top:var(--space-xl);display:flex;gap:var(--space-md);justify-content:center;flex-wrap:wrap">
      <a href="/teacher/" class="btn btn--outline" style="color:var(--text-primary);border-color:var(--border-color)">Teacher Dashboard</a>
      <a href="/lessons/" class="btn btn--cta">Lesson Grid</a>
    </div>
  </div>
</div>

<script src="/assets/js/progress.js" defer></script>
<script src="/assets/js/student-dashboard.js" defer></script>
