---
layout: layouts/base.njk
title: Curriculum
description: 150 structured math lessons across 7 phases covering counting, addition, subtraction, place value, and mental math for ages 5-10.
permalink: /curriculum/
---
<div class="content-page">
  <div class="content-page__inner" style="max-width:72rem">
    <h1 class="content-page__title">Curriculum Overview</h1>
    <p class="content-page__intro">Math Direct covers foundational math skills through 150 scripted lessons organized into 7 sequential phases. Each phase builds on the one before it.</p>

    <div class="curriculum-stats">
      <div class="curriculum-stat">
        <span class="curriculum-stat__number">150</span>
        <span class="curriculum-stat__label">Lessons</span>
      </div>
      <div class="curriculum-stat">
        <span class="curriculum-stat__number">68</span>
        <span class="curriculum-stat__label">Concepts</span>
      </div>
      <div class="curriculum-stat">
        <span class="curriculum-stat__number">7</span>
        <span class="curriculum-stat__label">Phases</span>
      </div>
      <div class="curriculum-stat">
        <span class="curriculum-stat__number">K&ndash;4</span>
        <span class="curriculum-stat__label">Grades</span>
      </div>
    </div>

    {% for phase in phases %}
    <div class="guide-section">
      <h2 class="guide-section__title">
        <a href="/phases/{{ phase.slug }}/" style="color:inherit;text-decoration:none">Phase {{ phase.id }}: {{ phase.title | replace("Phase " + phase.id + ": ", "") }}</a>
      </h2>
      <p class="curriculum-phase-meta">Lessons {{ phase.lessonRange }} &middot; {{ phase.conceptsIntroduced.length }} concepts</p>
      <p>{{ phase.description }}</p>

      {# Concepts table #}
      {% if phase.conceptsIntroduced.length > 0 %}
      <table class="curriculum-table">
        <thead>
          <tr>
            <th>Concept</th>
            <th>Lesson</th>
            <th>Type</th>
            <th>Example</th>
          </tr>
        </thead>
        <tbody>
          {% for c in phase.conceptsIntroduced %}
          <tr>
            <td><strong>{{ c.symbol }}</strong></td>
            <td><a href="/lessons/lesson-{{ c.lesson | pad }}/">{{ c.lesson }}</a></td>
            <td>{{ c.type }}</td>
            <td>{{ c.example }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% endif %}

      {# Skills #}
      <h3 style="font-size:0.8125rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-secondary);margin-top:var(--space-md)">Skills Developed</h3>
      <ul class="guide-tips">
        {% for skill in phase.skills %}
        <li>{{ skill }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}

    <div class="content-page__cta">
      <a href="/lessons/" class="btn btn--cta">Browse All Lessons</a>
      <a href="/roadmap/" class="btn btn--outline" style="color:var(--text-primary);border-color:var(--border-color)">View Roadmap</a>
    </div>
  </div>
</div>
