---
layout: layouts/base.njk
title: Learning Roadmap
description: Visual roadmap of the Math Direct program showing every lesson milestone from first numbers to two-digit arithmetic.
permalink: /roadmap/
bodyClass: page-guide
---
<div class="content-page">
  <div class="content-page__inner" style="max-width:72rem">
    <h1 class="content-page__title">Learning Roadmap</h1>
    <p class="content-page__intro">Follow the path from first numbers to two-digit arithmetic. Each dot is a lesson. Milestones mark new concepts introduced.</p>

    {# Legend #}
    <div class="roadmap-legend">
      <div class="roadmap-legend__item">
        <span class="roadmap-dot roadmap-dot--sample" style="width:1.25rem;height:1.25rem"></span>
        <span>Lesson</span>
      </div>
      <div class="roadmap-legend__item">
        <span class="roadmap-dot roadmap-dot--milestone roadmap-dot--sample" style="width:1.25rem;height:1.25rem"></span>
        <span>New concept introduced</span>
      </div>
      <div class="roadmap-legend__item">
        <span class="roadmap-stories__link" style="font-size:0.75rem;padding:0.15rem 0.5rem;pointer-events:none">Practice</span>
        <span>Practice set available</span>
      </div>
    </div>

    {% for phase in phases %}
    <section class="roadmap-phase">
      <div class="roadmap-phase__header">
        <h2 class="roadmap-phase__title"><a href="/phases/{{ phase.slug }}/">Phase {{ phase.id }}: {{ phase.title | replace("Phase " + phase.id + ": ", "") }}</a></h2>
        <span class="roadmap-phase__meta">Lessons {{ phase.lessonRange }} &middot; {{ phase.conceptsIntroduced.length }} concepts</span>
      </div>
      <p class="roadmap-phase__desc">{{ phase.description }}</p>

      <div class="roadmap-track">
        {% for lesson in lessons | where("phase", phase.id) %}
        {% set isMilestone = false %}
        {% for c in phase.conceptsIntroduced %}
          {% if c.lesson == lesson.id %}
            {% set isMilestone = true %}
          {% endif %}
        {% endfor %}
        <a href="/lessons/lesson-{{ lesson.id | pad }}/" class="roadmap-dot{% if isMilestone %} roadmap-dot--milestone{% endif %}" title="Lesson {{ lesson.id }}: {{ lesson.target }}">
          <span class="roadmap-dot__number">{{ lesson.id }}</span>
          {% if isMilestone %}
          <span class="roadmap-dot__sound">
            {% for c in phase.conceptsIntroduced %}{% if c.lesson == lesson.id %}{{ c.symbol }}{% endif %}{% endfor %}
          </span>
          {% endif %}
        </a>
        {% endfor %}
      </div>

      {# Practice sets and flashcards for this phase #}
      {% set phasePractice = collections.practice | where("data.phase", phase.id) %}
      {% if phasePractice.length > 0 %}
      <div class="roadmap-stories">
        <span class="roadmap-stories__label">Practice:</span>
        {% for item in phasePractice %}
        <a href="{{ item.url }}" class="roadmap-stories__link">{{ item.data.title }}</a>
        {% endfor %}
        <a href="/flashcards/?phase={{ phase.id }}" class="roadmap-stories__link">Flashcards</a>
      </div>
      {% endif %}
    </section>
    {% endfor %}

    <div class="content-page__cta">
      <a href="/lessons/" class="btn btn--cta">Start Lessons</a>
      <a href="/curriculum/" class="btn btn--outline" style="color:var(--text-primary);border-color:var(--border-color)">Curriculum Reference</a>
    </div>
  </div>
</div>
