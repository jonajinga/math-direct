---
layout: layouts/base.njk
title: Lessons
description: Browse all 150 math lessons organized by phase. Track your progress as you learn numbers, addition, and subtraction.
permalink: /lessons/
bodyClass: page-lessons
---
<div class="dashboard">
  <div class="dashboard__inner">

    {# Student Profile Selector #}
    <div id="profile-selector"></div>

    {% for phase in phases %}
    <section class="phase-section" id="phase-{{ phase.id }}">
      <h2 class="phase-section__title"><a href="/phases/{{ phase.slug }}/">Phase {{ phase.id }}: {{ phase.title | replace("Phase " + phase.id + ": ", "") }}</a></h2>
      <p class="phase-section__subtitle">Lessons {{ phase.lessonRange }} &middot; {{ phase.conceptsIntroduced.length }} concepts</p>
      <div class="lesson-grid">
        {% for lesson in lessons | where("phase", phase.id) %}
        <a href="/lessons/lesson-{{ lesson.id | pad }}/" class="lesson-card" data-lesson-id="{{ lesson.id }}">
          <span class="lesson-card__number">{{ lesson.id }}</span>
          <span class="lesson-card__target">{{ lesson.target }}</span>
        </a>
        {% endfor %}
      </div>
      {# Practice + Flashcard links for this phase #}
      {% set phasePractice = collections.practice | where("data.phase", phase.id) %}
      {% if phasePractice.length > 0 %}
      <div class="phase-links">
        <span class="phase-links__label">Practice:</span>
        {% for item in phasePractice %}
        <a href="{{ item.url }}" class="phase-links__link">{{ item.data.title }}</a>
        {% endfor %}
        <a href="/flashcards/?phase={{ phase.id }}" class="phase-links__link phase-links__link--fc">Flashcards</a>
      </div>
      {% endif %}
    </section>
    {% endfor %}

    {# Progress Actions #}
    <div class="progress-actions">
      <span class="progress-actions__title">Progress</span>
      <button class="btn--progress" id="btn-export-progress" title="Export progress" aria-label="Export progress">
        {% include "partials/icons/download.njk" %}
      </button>
      <button class="btn--progress" id="btn-import-progress" title="Import progress" aria-label="Import progress">
        {% include "partials/icons/upload.njk" %}
      </button>
      <button class="btn--progress" id="btn-reset-progress" title="Reset progress" aria-label="Reset progress">
        {% include "partials/icons/rotate-ccw.njk" %}
      </button>
      <input type="file" id="import-progress-input" class="progress-import-input" accept=".json">
    </div>

  </div>
</div>

<script src="/assets/js/progress.js" defer></script>
